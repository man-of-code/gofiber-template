#
# Required values for running the React test client
#
# Use the same value as ENCRYPTION_KEY from the Go server .env
VITE_ENCRYPTION_KEY=

# Admin key used for /admin/* endpoints (matches ADMIN_MASTER_KEY in the Go .env)
VITE_ADMIN_KEY=

#
# Optional defaults for the Admin panel
#
VITE_DEFAULT_CLIENT_NAME=acme-client
VITE_DEFAULT_ALLOWED_IPS=10.0.0.0/8
