# Required for auth and encryption
# NOTE: These should normally be generated using:
#   go run ./cmd/genenv
# The values below are placeholders only and MUST NOT be used in production.
ENCRYPTION_KEY=replace-with-64-char-hex-from-genenv
JWT_SECRET=replace-with-strong-secret-from-genenv
ADMIN_MASTER_KEY=replace-with-admin-master-key-from-genenv

# Optional
PORT=3000
DB_PATH=./data/app.db
ENV=dev
LOG_LEVEL=info
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=24h

# Rate limiting (Phase 5)
GLOBAL_RATE_LIMIT=1000
AUTH_RATE_LIMIT=10
API_RATE_LIMIT=200

# IP validation (Phase 4)
IP_MODE=off
TRUSTED_PROXIES=
GLOBAL_ALLOWED_IPS=
GLOBAL_BLOCKED_IPS=
TRUSTED_PROXY_DEPTH=1

# Token binding (Phase 4): strict, subnet, off
TOKEN_BINDING_MODE=strict

# Request body limit (bytes)
BODY_LIMIT=1048576
